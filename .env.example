# Supabase — obtenha em https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_KEY=sb_secret_...

# Resend — obtenha em https://resend.com/api-keys
RESEND_API_KEY=re_...

# E-mail do casal para receber confirmações de presença
COUPLE_EMAIL=seu@email.com

# Google Sheets (opcional — sync de RSVPs)
# Crie uma Service Account em https://console.cloud.google.com → IAM → Service Accounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=nome@projeto.iam.gserviceaccount.com
# Cole a chave privada JSON inteira (com \n literais, entre aspas)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# ID da planilha: extraído da URL https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=
